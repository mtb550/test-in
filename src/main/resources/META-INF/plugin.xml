<idea-plugin>
    <id>com.example.demo</id>
    <name>Test Case Manager</name>
    <vendor email="mtb550@gmail.com" url="https://mtb.com">initial</vendor>

    <description><![CDATA[
        Plugin to browse test projects, view features, and manage test cases with details and bug tracking.
    ]]></description>

    <!-- Required to access core IntelliJ APIs -->
    <depends>com.intellij.modules.platform</depends>


    <extensions defaultExtensionNs="com.intellij">

        <!-- 🧭 Left-side tool window: Test Case Explorer -->
        <toolWindow
                id="TestCaseExplorer"
                factoryClass="com.example.demo.TestCaseExplorerToolWindowFactory"
                anchor="left"
                icon="/icons/t1.png"
                secondary="true" />

        <!-- 🔍 Right-side tool window: Test Case Details -->
        <toolWindow
                id="TestCaseDetails"
                factoryClass="com.example.demo.TestCaseDetailsToolWindowFactory"
                anchor="right"
                icon="/icons/t1.png"
                secondary="true" />

        <!-- 📝 File editor provider for table editor -->
        <fileEditorProvider implementation="com.example.demo.TestCaseEditorProvider"/>
    </extensions>

    <actions>
        <!-- 📂 Menu action to show tree view manually -->
        <action
                id="com.example.demo.OpenTestTreeAction"
                class="com.example.demo.ShowTestTreeAction"
                text="Open Test Plan Tree"
                description="Show Test Case Explorer"
                icon="/icons/t1.png">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
            <action id="TestTreeContextMenuGroup"
                    class="com.example.demo.TestTreeContextMenuGroup"
                    text="Test Tree Context Menu"
                    popup="true"/>
    </actions>
</idea-plugin>
