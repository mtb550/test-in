<idea-plugin>
    <id>com.example.demo</id>
    <name>Test Case Manager</name>
    <vendor email="mtb550@gmail.com" url="https://mtb.com">initial</vendor>

    <description><![CDATA[
        Plugin to browse test projects, view features, and manage test cases with details and bug tracking.
    ]]></description>

    <!-- Required to access core IntelliJ APIs -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>TestNG-J</depends>
    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- 🧭 Left-side tool window: Test Case Explorer -->
        <toolWindow
                id="Explorer"
                factoryClass="com.example.explorer.TestCaseExplorerToolWindowFactory"
                anchor="left"
                icon="/icons/ant_dark.svg"
                secondary="true"/>

        <!-- 🔍 Right-side tool window: Test Case Details -->
        <toolWindow
                id="Details"
                factoryClass="com.example.viewer.TestCaseDetailsToolWindowFactory"
                anchor="right"
                icon="/icons/ant_dark.svg"
                secondary="true"/>

        <!-- 📝 File editor provider for table editor -->
        <fileEditorProvider implementation="com.example.editor.TestCaseEditorProvider"/>

        <notificationGroup id="Test Case Notifications"
                           displayType="BALLOON"
                           isLogByDefault="true"/>


    </extensions>

    <actions>
        <!-- 📂 Menu action to show tree view manually -->
        <action
                id="com.example.demo.OpenTestTreeAction"
                class="com.example.pojo.ShowTestTreeAction"
                text="Open Test Plan Tree"
                description="Show Test Case Explorer"
                icon="/icons/t1.png">
            <add-to-group group-id="ToolsMenu" anchor="last"/>

        </action>
        <action id="TestTreeContextMenuGroup"
                class="com.example.explorer.TestTreeContextMenuGroup"
                text="Test Tree Context Menu"
                popup="true"/>
    </actions>
</idea-plugin>
