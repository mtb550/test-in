<idea-plugin>
    <id>testGit.demo</id>
    <name>Test Case Manager</name>
    <vendor email="mtb550@gmail.com" url="https://mtb.com">initial</vendor>

    <description><![CDATA[
        Plugin to browse test projects, view features, and manage test cases with details and bug tracking.
    ]]></description>

    <!-- Required to access core IntelliJ APIs -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>TestNG-J</depends>
    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">

        <postStartupActivity implementation="testGit.settings.PluginPostStartupActivity"/>

        <!-- 🧭 Left-side tool window: Test Case Explorer -->
        <toolWindow
                id="TestGit"
                factoryClass="testGit.projectPanel.ProjectPanelToolWindowFactory"
                anchor="left"
                icon="AllIcons.General.Information"
                secondary="false"/>
        <!--        icon="/icons/ant_dark.svg"  OLD ICON -->

        <!-- 🔍 Right-side tool window: Test Case Details -->
        <toolWindow
                id="Details"
                factoryClass="testGit.viewPanel.TestCaseDetailsToolWindowFactory"
                anchor="bottom"
                icon="AllIcons.General.Information"
                secondary="false"/>

        <!-- 📝 File editor providers -->
        <fileEditorProvider implementation="testGit.editorPanel.Provider"/>
        <fileEditorProvider implementation="testGit.projectPanel.testPlan.TestRunFileEditorProvider"/>

        <!-- 🔔 Notification group -->
        <notificationGroup id="Test Case Notifications"
                           displayType="BALLOON"
                           isLogByDefault="true"/>

        <applicationService serviceImplementation="testGit.settings.AppSettingsState"/>

        <applicationConfigurable
                instance="testGit.settings.AppSettingsConfigurable"
                id="testGit.settings.AppSettingsConfigurable"
                displayName="TestGit"
                groupId="tools"/>

    </extensions>

    <actions>
        <!-- 📂 Menu action to show tree view manually -->
        <action
                id="testGit.demo.OpenTestTreeAction"
                class="testGit.pojo.ShowTestTreeAction"
                text="Open Test Plan Tree"
                description="Show test case explorer"
                icon="/icons/t1.png">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <group id="TestTreeContextMenuGroup"
               class="testGit.projectPanel.ProjectPanelContext"
               text="Test Tree Context Menu"
               popup="true">
        </group>
    </actions>
</idea-plugin>
