<idea-plugin>

    <!-- ================================================================== -->
    <!-- Identity                                                           -->
    <!-- ================================================================== -->
    <id>org.testin</id>
    <name>Testin</name>
    <version>2.0.1-SNAPSHOT</version>
    <vendor email="mtb550@gmail.com" url="https://github.com/mtb550/test-in">Muteb Almughyiri</vendor>
    <resource-bundle>messages</resource-bundle>
    <description><![CDATA[
        <b>test in</b> — a QC management plugin for IntelliJ-based IDEs.<br/><br/>
        Browse test projects, manage test cases, track test runs, and integrate
        with git version control — all from within your IDE.
    ]]></description>
    <change-notes><![CDATA[
        <b>2.0.0</b>
        <ul>
            <li>Initial release</li>
            <li>Test case editor with filtering, search, and pagination</li>
            <li>Test run creation and opening editor</li>
            <li>Settings page for global configuration</li>
        </ul>
    ]]></change-notes>

    <!-- ================================================================== -->
    <!-- Compatibility                                                        -->
    <!-- ================================================================== -->
    <idea-version since-build="251"/>

    <!-- ================================================================== -->
    <!-- Dependencies                                                         -->
    <!-- ================================================================== -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>Git4Idea</depends>
    <depends>TestNG-J</depends>

    <!-- ================================================================== -->
    <!-- Extensions                                                           -->
    <!-- ================================================================== -->
    <extensions defaultExtensionNs="com.intellij">
        <!-- File editors -->
        <fileEditorProvider
                implementation="org.testin.editorPanel.UnifiedEditorProvider"
        />

        <!-- Services -->
        <applicationService
                serviceImplementation="org.testin.settings.AppSettingsState"
        />

        <!-- Tool windows -->
        <toolWindow
                id="testin.tree"
                factoryClass="org.testin.projectPanel.Main"
                anchor="left"
                icon="/icons/pluginIcon.svg"
                secondary="false"
                doNotActivateOnStart="true"
        />

        <toolWindow
                id="testin.view"
                factoryClass="org.testin.viewPanel.ViewToolWindowFactory"
                anchor="right"
                icon="/icons/pluginIcon.svg"
                secondary="false"
                doNotActivateOnStart="true"
        />

        <!-- Notifications -->
        <notificationGroup
                id="testin.notifications"
                displayType="BALLOON"
                isLogByDefault="true"
                bundle="messages"
                key="testin.display.name"
        />

        <!-- Settings -->
        <applicationConfigurable
                instance="org.testin.settings.AppSettingsConfigurable"
                id="org.testin.settings.AppSettingsConfigurable"
                key="testin.display.name"
                bundle="messages"
                groupId="tools"
        />

        <!-- gutter -->
        <codeInsight.lineMarkerProvider
                language="JAVA"
                implementationClass="org.testin.util.gutter.TestMethodGutter"
        />

    </extensions>

</idea-plugin>